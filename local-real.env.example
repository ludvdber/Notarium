REM ============================================================
REM  Secrets pour le test RÉEL local (profil "local").
REM  Copie ce fichier en  local-real.env  et remplis les valeurs.
REM  local-real.env est gitignoré — ne JAMAIS le committer.
REM ============================================================

REM --- Discord OAuth2 (portail https://discord.com/developers/applications) ---
REM  Dans ton app Discord > OAuth2 > Redirects, ajoute EXACTEMENT :
REM    http://localhost:8080/login/oauth2/code/discord
REM  Scopes utilisés par Freenote : identify, email
set DISCORD_CLIENT_ID=ton-client-id
set DISCORD_CLIENT_SECRET=ton-client-secret

REM --- SMTP réel (Brevo conseillé : https://app.brevo.com > SMTP & API > SMTP) ---
set SMTP_HOST=smtp-relay.brevo.com
set SMTP_PORT=587
set SMTP_USERNAME=ton-login-smtp-brevo
set SMTP_PASSWORD=ta-cle-smtp-brevo
