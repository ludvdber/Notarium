# Normalise toutes les fins de ligne en LF dans le repo (quel que soit l'OS).
* text=auto eol=lf

# Scripts Windows : garder CRLF (sinon ils peuvent mal s'exécuter).
*.bat text eol=crlf
*.cmd text eol=crlf

# Scripts shell : toujours LF (sinon ils cassent sur Linux/LXC).
*.sh   text eol=lf
gradlew text eol=lf

# Binaires : ne jamais convertir.
*.jar  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.woff  binary
*.woff2 binary
