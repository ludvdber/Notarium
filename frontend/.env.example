# Frontend environment template — copy to frontend/.env and tweak as needed.
# Vite only exposes variables prefixed with VITE_ to the client bundle.

# Backend API base URL. In dev, Vite proxies /api → localhost:8080 via vite.config.ts,
# so leaving this unset works out of the box. In prod, set to the deployed backend URL.
VITE_API_URL=

# Donation / supporter link (rendered in Footer, AdBanner, etc.).
# Default falls back to the one hard-coded in src/lib/constants.ts.
VITE_KOFI_URL=https://ko-fi.com/ludovic01

# Discord invite URL (CTA in Navbar + Footer). Leave unset to use the baked-in default.
VITE_DISCORD_INVITE_URL=

# Discord server widget ID (DelegatesDiscord embed). See src/lib/constants.ts.
VITE_DISCORD_WIDGET_ID=

# GitHub repo URL (Footer link). Leave unset to use the default.
VITE_GITHUB_URL=

# Sentry frontend DSN (runtime error tracking). Leave unset to disable.
# Install with: npm i @sentry/react && wire from src/main.tsx behind a `if (import.meta.env.VITE_SENTRY_DSN)` guard.
VITE_SENTRY_DSN=
