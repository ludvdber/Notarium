# ============================================
# Notarium - Environment Variables
# ============================================
# Copy this file to .env and fill in the values.

# --- Server ---
SERVER_PORT=8080

# --- PostgreSQL ---
DB_URL=jdbc:postgresql://localhost:5432/notarium
DB_USERNAME=notarium
DB_PASSWORD=notarium

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- MinIO (Object Storage) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=notarium

# --- Meilisearch ---
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=dev-master-key

# --- JWT ---
JWT_SECRET=change-me-to-a-secure-random-secret-at-least-256-bits

# --- OAuth2 Discord ---
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# --- OAuth2 Google ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- SMTP (Email) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=

# --- Email Hash Salt ---
EMAIL_HASH_SALT=change-me-to-a-secure-random-salt

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
