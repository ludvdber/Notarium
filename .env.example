# ============================================
# Freenote - Environment Variables
# ============================================
# Copy this file to .env and fill in the values.

# --- Server ---
SERVER_PORT=8080

# --- PostgreSQL ---
DB_URL=jdbc:postgresql://localhost:5432/freenote
DB_USERNAME=freenote
DB_PASSWORD=freenote

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- MinIO (Object Storage) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=freenote-docs

# --- Meilisearch ---
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=dev-master-key

# --- JWT ---
JWT_SECRET=change-me-to-a-secure-random-secret-at-least-256-bits

# --- OAuth2 Discord ---
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# --- OAuth2 Google ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- SMTP (Email) — Brevo free tier recommended (300/day, Paris-hosted, RGPD-friendly) ---
# Create a free account at https://brevo.com → SMTP & API → SMTP keys
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your-brevo-smtp-user
SMTP_PASSWORD=your-brevo-smtp-password

# --- Email Hash Salt ---
EMAIL_HASH_SALT=change-me-to-a-secure-random-salt

# --- Ko-fi Webhook ---
# Found in Ko-fi > Settings > API > Webhook Verification Token
KOFI_VERIFICATION_TOKEN=your-kofi-verification-token

# --- Frontend URL (used for OAuth2 redirect after login) ---
FRONTEND_URL=http://localhost:3000

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
